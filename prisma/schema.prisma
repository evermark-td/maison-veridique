generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------- auth

enum UserRole {
  USER
  EDITOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  orders       Order[]
  addresses    Address[]
  wishlist     WishlistItem[]
  carts        Cart[]
  posts        JournalPost[]
  media        Media[]
  enquiries    Enquiry[]      @relation("EnquiryHandler")
  auditLogs    AuditLog[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ---------------------------------------------------------------- catalogue

model Collection {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  subtitle    String?
  season      String?
  year        Int?
  description String?
  heroMediaId String?
  isPublished Boolean   @default(false)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  heroMedia Media?    @relation("CollectionHero", fields: [heroMediaId], references: [id], onDelete: SetNull)
  products  Product[]

  @@index([isPublished, publishedAt])
  @@index([sortOrder])
}

model Category {
  id       String  @id @default(cuid())
  slug     String  @unique
  name     String
  parentId String?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
}

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String
  story            String?
  composition      String?
  careInstructions String?
  basePrice        Decimal  @db.Decimal(10, 2)
  currency         String   @default("EUR")
  collectionId     String?
  categoryId       String?
  isFeatured       Boolean  @default(false)
  isPublished      Boolean  @default(false)
  sortOrder        Int      @default(0)
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  collection Collection?      @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  category   Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants   ProductVariant[]
  images     ProductImage[]
  wishlisted WishlistItem[]

  @@index([collectionId])
  @@index([categoryId])
  @@index([isPublished, isFeatured])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  sku       String  @unique
  colorName String
  colorHex  String
  size      String
  price     Decimal @db.Decimal(10, 2)
  stock     Int     @default(0)
  isActive  Boolean @default(true)

  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, colorName, size])
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  variantId String?
  mediaId   String
  alt       String
  sortOrder Int     @default(0)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  media   Media           @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Media {
  id           String   @id @default(cuid())
  url          String
  blurDataUrl  String?
  width        Int
  height       Int
  mimeType     String
  alt          String   @default("")
  uploadedById String?
  createdAt    DateTime @default(now())

  uploadedBy      User?          @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  productImages   ProductImage[]
  collectionHeros Collection[]   @relation("CollectionHero")
  journalCovers   JournalPost[]  @relation("JournalCover")
  pressLogos      PressMention[] @relation("PressLogo")
  outletLogos     Testimonial[]  @relation("TestimonialLogo")

  @@index([createdAt])
}

// ---------------------------------------------------------------- editorial & marketing

model JournalPost {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  excerpt        String
  contentMdx     String
  coverMediaId   String?
  authorId       String?
  tags           String[]
  readingMinutes Int       @default(3)
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  coverMedia Media? @relation("JournalCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  author     User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([isPublished, publishedAt])
}

model Testimonial {
  id           String  @id @default(cuid())
  quoteText    String
  authorName   String
  authorTitle  String?
  outletLogoId String?
  sortOrder    Int     @default(0)
  isPublished  Boolean @default(true)

  outletLogo Media? @relation("TestimonialLogo", fields: [outletLogoId], references: [id], onDelete: SetNull)

  @@index([isPublished, sortOrder])
}

model PressMention {
  id          String    @id @default(cuid())
  outletName  String
  logoMediaId String?
  url         String?
  quote       String?
  publishedAt DateTime?
  sortOrder   Int       @default(0)

  logo Media? @relation("PressLogo", fields: [logoMediaId], references: [id], onDelete: SetNull)
}

model FaqItem {
  id          String  @id @default(cuid())
  question    String
  answer      String
  category    String  @default("General")
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)

  @@index([isPublished, sortOrder])
}

model ServiceTier {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  tagline       String
  priceLabel    String
  features      String[]
  isHighlighted Boolean  @default(false)
  sortOrder     Int      @default(0)
}

model Boutique {
  id      String  @id @default(cuid())
  slug    String  @unique
  name    String
  address String
  city    String
  country String
  lat     Float?
  lng     Float?
  phone   String?
  hours   Json?

  enquiries Enquiry[]
}

// ---------------------------------------------------------------- commerce

model Cart {
  id           String   @id @default(cuid())
  userId       String?
  sessionToken String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int    @default(1)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  userId            String?
  email             String
  status            OrderStatus @default(PENDING)
  subtotal          Decimal     @db.Decimal(10, 2)
  shipping          Decimal     @default(0) @db.Decimal(10, 2)
  tax               Decimal     @default(0) @db.Decimal(10, 2)
  total             Decimal     @db.Decimal(10, 2)
  currency          String      @default("EUR")
  shippingAddressId String?
  billingAddressId  String?
  placedAt          DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  shippingAddress Address?    @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddress  Address?    @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  @@index([userId])
  @@index([status, placedAt])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  variantId     String?
  nameSnapshot  String
  skuSnapshot   String
  priceSnapshot Decimal @db.Decimal(10, 2)
  quantity      Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Address {
  id         String  @id @default(cuid())
  userId     String?
  fullName   String
  line1      String
  line2      String?
  city       String
  region     String?
  postalCode String
  country    String
  phone      String?

  user             User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders   Order[] @relation("ShippingAddress")
  billingOrders    Order[] @relation("BillingAddress")

  @@index([userId])
}

// ---------------------------------------------------------------- crm & ops

enum EnquiryType {
  APPOINTMENT
  BESPOKE
  PRESS
  GENERAL
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

model Enquiry {
  id            String        @id @default(cuid())
  type          EnquiryType   @default(GENERAL)
  fullName      String
  email         String
  phone         String?
  boutiqueId    String?
  preferredDate DateTime?
  message       String
  status        EnquiryStatus @default(NEW)
  handledById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  boutique  Boutique? @relation(fields: [boutiqueId], references: [id], onDelete: SetNull)
  handledBy User?     @relation("EnquiryHandler", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model Subscriber {
  id            String    @id @default(cuid())
  email         String    @unique
  token         String    @unique
  confirmedAt   DateTime?
  unsubscribedAt DateTime?
  source        String    @default("footer")
  createdAt     DateTime  @default(now())
}

model SiteSetting {
  key       String   @id
  valueJson Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  diffJson  Json?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([createdAt])
}
